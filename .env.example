# Add your MLflow/Groq API configuration here.
# Copy this file to `.env` and fill in the values before running.

# GROQ API key (required)
GROQ_API_KEY=your_groq_api_key_here

# MLflow tracking server URI (optional)
# If you are running MLflow locally, the default is usually http://127.0.0.1:5000
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Optional: override the model used for prediction
# MODEL_NAME=llama-3.1-8b-instant

# Optional: set a custom prompt name and experiment name
# PROMPT_NAME=support-ticket-classifier-prompt
# MLFLOW_EXPERIMENT=Support_Ticket_Classification_project

# Optional: enable basic auth for Gradio UI (Hugging Face Spaces or local)
# HF_APP_USERNAME=myuser
# HF_APP_PASSWORD=mypassword
