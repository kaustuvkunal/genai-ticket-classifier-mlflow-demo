# Add your MLflow and LLM API configuration here.
# Copy this file to `.env` and fill in the values before running.
# IMPORTANT: NEVER commit this file with real API keys!

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================
# Choose which provider to use by default
# Options: groq, openai, azure_openai, gemini
# You can also override per-command with --llm-provider flag
LLM_PROVIDER=provider_name_here

# ============================================================================
# PROVIDER-SPECIFIC MODEL NAMES
# ============================================================================
# Each provider has its own model configuration
GROQ_MODEL_NAME=model_name_here
OPENAI_MODEL_NAME=model_name_here
AZURE_OPENAI_MODEL_NAME=model_name_here
GEMINI_MODEL_NAME=model_name_here


# ============================================================================
# GROQ CONFIGURATION
# ============================================================================
# GROQ API key (required if using LLM_PROVIDER=groq)
# Get your key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# OPENAI CONFIGURATION (Standard OpenAI API)
# ============================================================================
# API key (required if using LLM_PROVIDER=openai)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

 
# ============================================================================
# AZURE OPENAI CONFIGURATION
# ============================================================================
# Uncomment if using LLM_PROVIDER=azure_openai
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ============================================================================
# GOOGLE GEMINI CONFIGURATION
# ============================================================================
# API key (required if using LLM_PROVIDER=gemini)
# GOOGLE_API_KEY=your_google_api_key_here


# MLflow tracking server URI (optional)
# If you are running MLflow locally, the default is usually http://127.0.0.1:5000
MLFLOW_TRACKING_URI=http://127.0.0.1:5000


# Optional: set a custom prompt name and experiment name
PROMPT_TEMPLATE_NAME= 
MLFLOW_EXPERIMENT= 

# Optional: enable basic auth for Gradio UI (Hugging Face Spaces or local)
USERNAME= 
PASSWD= 