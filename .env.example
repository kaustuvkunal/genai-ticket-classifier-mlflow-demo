# Add your MLflow and LLM API configuration here.
# Copy this file to `.env` and fill in the values before running.
# IMPORTANT: NEVER commit this file with real API keys!

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================
# Choose which provider to use by default.
# Options: groq, openai
LLM_PROVIDER=groq

# ============================================================================
# PROVIDER-SPECIFIC MODEL NAMES
# ============================================================================
# Serving model used for prediction and evaluation.
GROQ_MODEL_NAME=llama-3.3-70b-versatile
OPENAI_MODEL_NAME=gpt-4o
OPENAI_GL_MODEL_NAME=gpt-4o
AZURE_OPENAI_MODEL_NAME=gpt-4o
GEMINI_MODEL_NAME=gemini-pro-2.5

# Optional: set MODEL_NAME to override the provider-specific model above.
# MODEL_NAME=llama-3.1-8b-instant

# ============================================================================
# GROQ CONFIGURATION
# ============================================================================
# Required when LLM_PROVIDER=groq. Get your key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# OPENAI CONFIGURATION (Standard OpenAI API)
# ============================================================================
# Required when LLM_PROVIDER=openai. Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# OPENAI GL CONFIGURATION (GreatLearning AIBE Endpoint)
# ============================================================================
# Required when LLM_PROVIDER=openai_gl.
OPENAI_GL_API_KEY=your_openai_gl_api_key_here
OPENAI_GL_BASE_URL=https://aibe.mygreatlearning.com/openai/v1

# ============================================================================
# AZURE OPENAI CONFIGURATION
# ============================================================================
# Uncomment if using LLM_PROVIDER=azure_openai.
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ============================================================================
# GOOGLE GEMINI CONFIGURATION
# ============================================================================
# Uncomment if using LLM_PROVIDER=gemini.
# GOOGLE_API_KEY=your_google_api_key_here

# ============================================================================
# MLFLOW CONFIGURATION
# ============================================================================
# Tracking server URI. Run `mlflow ui` locally or point to a remote server.
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# MLflow experiment and prompt registry names.
MLFLOW_EXPERIMENT=Support_Ticket_Classification_project
PROMPT_NAME=support-ticket-classifier-prompt

# ============================================================================
# OPTIMIZATION SETTINGS
# ============================================================================
# Maximum number of scorer calls during prompt optimization.
MAX_METRIC_CALLS=64

# Reflection (judge) model used by the optimizer — separate from the serving model.
GROQ_REFLECTION_MODEL=llama-3.3-70b-versatile
OPENAI_REFLECTION_MODEL=gpt-4o

# ============================================================================
# LLM INFERENCE SETTINGS
# ============================================================================
# Sampling temperature: 0.0 = deterministic, higher = more creative.
LLM_TEMPERATURE=0.0

# Maximum tokens in the classifier output (category label is short, 32 is sufficient).
LLM_MAX_TOKENS=32

# ============================================================================
# GRADIO UI (optional)
# ============================================================================
# Basic auth credentials for the Gradio UI (Hugging Face Spaces or local).
USERNAME=your_username_here
PASSWD=your_password_here